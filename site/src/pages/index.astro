---
// Homepage — hero, features, CTA
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Terminal-first cybersecurity and AI security assessment platform. Scan, analyze, and report — all from the command line.">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-slate-950 text-white">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-blue-900/30 via-slate-950 to-slate-950"></div>
    <div class="relative mx-auto max-w-6xl px-4 py-24 md:py-32">
      <div class="max-w-2xl">
        <p class="text-blue-400 text-sm font-medium mb-3 tracking-wide uppercase">Open Source Security</p>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-tight mb-6">
          Security assessments<br />from your terminal.
        </h1>
        <p class="text-lg text-slate-400 mb-8 max-w-xl">
          BeGuardit is a terminal-first platform for cybersecurity and AI security assessments.
          Collect evidence, evaluate policies, trace attack paths, and generate compliance-ready reports.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/install" class="inline-flex items-center px-5 py-2.5 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition-colors">
            Install BeGuardit
          </a>
          <a href="/docs" class="inline-flex items-center px-5 py-2.5 bg-white/10 text-white rounded-lg font-medium hover:bg-white/20 transition-colors border border-white/20">
            Read the docs
          </a>
        </div>
      </div>

      <!-- Terminal preview -->
      <div class="mt-12 md:mt-16 bg-slate-900 rounded-xl border border-slate-800 shadow-2xl overflow-hidden max-w-3xl">
        <div class="flex items-center gap-1.5 px-4 py-2.5 bg-slate-800/60 border-b border-slate-800">
          <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
          <span class="text-xs text-slate-500 ml-2 font-mono">terminal</span>
        </div>
        <div class="p-4 font-mono text-sm leading-relaxed">
          <p class="text-slate-500">$ <span class="text-green-400">npx beguardit start</span> --profile deep --categories cyber,ai</p>
          <p class="text-slate-400 mt-2">&nbsp;&nbsp;Collecting evidence...</p>
          <p class="text-slate-400">&nbsp;&nbsp;&nbsp; os-info        <span class="text-green-400">done</span> (0.3s)</p>
          <p class="text-slate-400">&nbsp;&nbsp;&nbsp; network        <span class="text-green-400">done</span> (1.2s)</p>
          <p class="text-slate-400">&nbsp;&nbsp;&nbsp; services       <span class="text-green-400">done</span> (0.8s)</p>
          <p class="text-slate-400">&nbsp;&nbsp;&nbsp; ai-runtimes    <span class="text-green-400">done</span> (0.5s)</p>
          <p class="text-slate-400">&nbsp;&nbsp;&nbsp; ai-models      <span class="text-green-400">done</span> (1.1s)</p>
          <p class="text-slate-400 mt-2">&nbsp;&nbsp;Evaluating 20 policy rules...</p>
          <p class="text-slate-400">&nbsp;&nbsp;Building correlation graph...</p>
          <p class="text-slate-400">&nbsp;&nbsp;Found <span class="text-yellow-400">3 attack paths</span></p>
          <p class="text-slate-400 mt-2">&nbsp;&nbsp;<span class="text-red-400">2 critical</span> &middot; <span class="text-orange-400">4 high</span> &middot; <span class="text-yellow-400">7 medium</span> &middot; <span class="text-blue-400">3 low</span></p>
          <p class="text-green-400 mt-2">&nbsp;&nbsp;Report saved to ./beguardit-report.json</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-bold mb-3">Built for security professionals</h2>
        <p class="text-slate-500 max-w-lg mx-auto">
          A complete assessment toolkit — from evidence collection to compliance reporting.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="border border-slate-200 rounded-xl p-6">
          <div class="w-10 h-10 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center text-lg font-bold mb-4">10</div>
          <h3 class="font-semibold text-lg mb-2">Collector Plugins</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            6 cybersecurity collectors (OS, network, services, packages, users, filesystem) and
            4 AI-specific collectors (runtimes, models, prompts, RAG).
          </p>
        </div>

        <div class="border border-slate-200 rounded-xl p-6">
          <div class="w-10 h-10 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center text-lg font-bold mb-4">20</div>
          <h3 class="font-semibold text-lg mb-2">Policy Rules</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            9 cyber rules and 11 AI rules with CVSS v3.1 severity classification.
            Automatic attack path detection via BFS graph traversal.
          </p>
        </div>

        <div class="border border-slate-200 rounded-xl p-6">
          <div class="w-10 h-10 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center text-lg font-bold mb-4">4</div>
          <h3 class="font-semibold text-lg mb-2">Report Formats</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            JSON canonical (SHA-256 tamper-evident), HTML, PDF, and SARIF v2.1.0
            for GitHub Code Scanning and Azure DevOps integration.
          </p>
        </div>

        <div class="border border-slate-200 rounded-xl p-6">
          <div class="w-10 h-10 bg-green-100 text-green-600 rounded-lg flex items-center justify-center text-lg mb-4">&#9889;</div>
          <h3 class="font-semibold text-lg mb-2">Correlation Engine</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Directed graph with BFS attack path traversal.
            Cross-category chaining escalates composite severity when findings combine.
          </p>
        </div>

        <div class="border border-slate-200 rounded-xl p-6">
          <div class="w-10 h-10 bg-purple-100 text-purple-600 rounded-lg flex items-center justify-center text-lg mb-4">&#9881;</div>
          <h3 class="font-semibold text-lg mb-2">REST API + Portal</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            FastAPI backend with multi-tenant RBAC.
            React 18 portal for browsing assessments, managing teams, and downloading reports.
          </p>
        </div>

        <div class="border border-slate-200 rounded-xl p-6">
          <div class="w-10 h-10 bg-amber-100 text-amber-600 rounded-lg flex items-center justify-center text-lg mb-4">&#128274;</div>
          <h3 class="font-semibold text-lg mb-2">Security-First</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            argon2id password hashing, session-based auth with HttpOnly cookies,
            tenant-scoped data isolation, and append-only audit log.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick start -->
  <section class="py-16 bg-slate-50 border-y border-slate-200">
    <div class="mx-auto max-w-6xl px-4">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold mb-3">Get started in 30 seconds</h2>
      </div>

      <div class="max-w-2xl mx-auto space-y-6">
        <div class="bg-white border border-slate-200 rounded-xl p-5">
          <p class="text-xs text-slate-400 uppercase font-medium mb-2">Step 1 — Install</p>
          <code class="block bg-slate-950 text-green-400 px-4 py-3 rounded-lg text-sm font-mono">
            npm install -g @beguardit/cli
          </code>
        </div>

        <div class="bg-white border border-slate-200 rounded-xl p-5">
          <p class="text-xs text-slate-400 uppercase font-medium mb-2">Step 2 — Configure</p>
          <code class="block bg-slate-950 text-green-400 px-4 py-3 rounded-lg text-sm font-mono">
            beguardit config --set profile=deep --set categories=cyber,ai
          </code>
        </div>

        <div class="bg-white border border-slate-200 rounded-xl p-5">
          <p class="text-xs text-slate-400 uppercase font-medium mb-2">Step 3 — Run</p>
          <code class="block bg-slate-950 text-green-400 px-4 py-3 rounded-lg text-sm font-mono">
            beguardit start
          </code>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to assess your security posture?</h2>
      <p class="text-slate-500 mb-8 max-w-md mx-auto">
        BeGuardit is open source and free to use. Install it now and run your first assessment.
      </p>
      <div class="flex justify-center gap-3">
        <a href="/install" class="inline-flex items-center px-6 py-3 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition-colors">
          Install now
        </a>
        <a href="https://github.com/benchbrex-USA/BEGUARDIT-CLI" class="inline-flex items-center px-6 py-3 border border-slate-300 rounded-lg font-medium hover:bg-slate-50 transition-colors">
          View on GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
