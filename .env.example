# ============================================================================
# BeGuardit — Environment Variables
# Source: ARCH-002-2026-03-17, Section 14.2
# ============================================================================
# Copy this file to .env and fill in values.
# NEVER commit .env to source control.
# ============================================================================

# --- Database (API + Worker) ------------------------------------------------
# PostgreSQL connection string (asyncpg driver for SQLAlchemy async)
DATABASE_URL=postgresql+asyncpg://bg_dev:dev_password@postgres:5432/beguardit

# --- Redis (API + Worker) ---------------------------------------------------
# Used for: job queue broker, session store, rate-limit counters
REDIS_URL=redis://redis:6379/0

# --- API Security -----------------------------------------------------------
# 32-byte hex string for session signing. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-key

# Session cookie max age in seconds (default: 24 hours)
SESSION_TTL_SECONDS=86400

# --- CORS (API) -------------------------------------------------------------
# Comma-separated allowed origins. Must include portal URL.
CORS_ORIGINS=http://localhost:5173

# --- Worker -----------------------------------------------------------------
# Directory where generated report files (HTML/PDF/SARIF) are stored
REPORT_STORAGE_PATH=/data/reports

# --- Logging (All components) -----------------------------------------------
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Rate Limiting (API) ----------------------------------------------------
# Requests per minute per IP (general endpoints)
RATE_LIMIT_DEFAULT=100

# Login attempts per minute per email
RATE_LIMIT_LOGIN=10

# --- Password Hashing (API) -------------------------------------------------
# Argon2id is preferred (memory=64MB, iterations=3, parallelism=4).
# Bcrypt rounds used only as fallback.
BCRYPT_ROUNDS=12
